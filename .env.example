# ──────────────────────────────────────────────────────────────
# Template de variáveis de ambiente. Copie para .env e preencha:
#   cp .env.example .env
# Convenção de nomes segue o template oficial do desafio.
# ──────────────────────────────────────────────────────────────

# ── OpenAI (provider escolhido neste projeto) ─────────────────
OPENAI_API_KEY=sk-sua-chave-aqui
OPENAI_EMBEDDING_MODEL='text-embedding-3-small'

# LLM usado para responder. O enunciado menciona "gpt-5-nano";
# ajuste conforme a disponibilidade na sua conta (fallback: gpt-4o-mini).
OPENAI_MODEL=gpt-5-nano

# ── Google/Gemini (alternativa — não usada por padrão) ────────
GOOGLE_API_KEY=
GOOGLE_EMBEDDING_MODEL='models/embedding-001'

# ── Banco e ingestão ──────────────────────────────────────────
# Bate com o docker-compose.yml do template (postgres/postgres, db "rag", porta 5432).
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rag
PG_VECTOR_COLLECTION_NAME=document_chunks
PDF_PATH=document.pdf
